{
  "name": "weather-daily-backend",
  "version": "1.0.0",
  "description": "Fetches daily weather from Open-Meteo and pushes it to Telegram, Viber, and Messenger bots on a schedule.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "send-now": "node src/sendNow.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^3.0.3"
  }
}
