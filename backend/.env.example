# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
# Public HTTPS URL of this server (for webhooks). Use ngrok in dev.
PUBLIC_URL=

# ─── Location & schedule ──────────────────────────────────────────────────
LOCATION_NAME=Manila
# Optional: skip geocoding by giving exact coordinates.
# LATITUDE=14.5995
# LONGITUDE=120.9842
TZ_NAME=Asia/Manila
# Daily send time as cron (min hour dom mon dow). Default 07:00 daily.
DAILY_CRON=0 7 * * *

# Units
TEMP_UNIT=celsius        # celsius | fahrenheit
WIND_UNIT=kmh            # kmh | mph | ms | kn

# ─── Telegram (easiest — start here) ──────────────────────────────────────
# 1. Message @BotFather -> /newbot -> copy the token below.
# 2. Message your new bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
# Owner who receives the daily user-statistics report. Defaults to the first
# TELEGRAM_CHAT_IDS above if left blank. Send /report to the bot for it on demand.
OWNER_CHAT_ID=
# When to send the owner report (cron, in TZ_NAME). Default 08:00 daily.
OWNER_REPORT_CRON=0 8 * * *

# ─── Viber ────────────────────────────────────────────────────────────────
# Create a bot at https://partners.viber.com and paste the auth token.
VIBER_BOT_TOKEN=
VIBER_SENDER_NAME=Weather Bot

# ─── Messenger (Meta) ─────────────────────────────────────────────────────
# ⚠️ Daily unsolicited messages require Meta's Recurring Notifications /
#    approved message tags. See README. Page access token + verify token:
MESSENGER_PAGE_TOKEN=
MESSENGER_VERIFY_TOKEN=weather_verify
MESSENGER_RECIPIENT_IDS=
